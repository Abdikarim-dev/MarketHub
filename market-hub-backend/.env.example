# ---------------------------------------------------------------------------
# MarketHub API — environment variables
# Copy this file to `.env` and adjust the values for your environment.
# ---------------------------------------------------------------------------

# Core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database ---------------------------------------------------------------
# Option A: use a single DATABASE_URL (takes priority over everything below)
# DATABASE_URL=postgres://markethub:markethub@localhost:5432/markethub
#
# Option B: use discrete PostgreSQL settings (the production default)
POSTGRES_DB=markethub
POSTGRES_USER=markethub
POSTGRES_PASSWORD=markethub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
#
# Option C: quick local development / running tests without PostgreSQL
USE_SQLITE=False

# --- JWT --------------------------------------------------------------------
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- CORS -------------------------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Throttling / rate limiting --------------------------------------------
THROTTLE_ANON=60/min
THROTTLE_USER=1000/min

# --- Redis (optional; falls back to in-memory cache when empty) ------------
REDIS_URL=redis://localhost:6379/0

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
DEFAULT_CURRENCY=usd

# --- Cloudinary (optional production media storage) -------------------------
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
